{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "name": "SWA Registration",
      "request": "launch",
      "command": "swa start --config-name registration",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "AzureAIProxy",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: proxy",
      "program": "${workspaceFolder}/src/AzureAIProxy/bin/Debug/net10.0/AzureAIProxy.dll",
      "cwd": "${workspaceFolder}/src/AzureAIProxy",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://127.0.0.1:8001"
      }
    },
    {
      "name": "AzureAIProxy.Admin",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: admin",
      "program": "${workspaceFolder}/src/AzureAIProxy.Admin/bin/Debug/net10.0/AzureAIProxy.Admin.dll",
      "cwd": "${workspaceFolder}/src/AzureAIProxy.Admin",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Application started\\. Press Ctrl\\+C to shut down\\.",
        "uriFormat": "http://127.0.0.1:8000/account/login"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://127.0.0.1:8000"
      }
    }
  ],
  "compounds": [
    {
      "name": "Run all",
      "configurations": [
        "AzureAIProxy",
        "AzureAIProxy.Admin",
        "SWA Registration"
      ],
      "presentation": {
        "hidden": false,
        "group": "Frontend",
        "order": 1
      },
      "stopAll": true
    }
  ]
}
