{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "options": {
        "cwd": "${workspaceFolder}/src/registration"
      },
      "script": "install",
      "label": "npm: install"
    },
    {
      "type": "npm",
      "options": {
        "cwd": "${workspaceFolder}/src/registration"
      },
      "script": "build",
      "label": "npm: build"
    },
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/AzureAIProxy.sln",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: proxy",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/AzureAIProxy/AzureAIProxy.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: admin",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/AzureAIProxy.Admin/AzureAIProxy.Admin.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/src/AzureAIProxy.sln",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/src/AzureAIProxy.sln"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "docker build: proxy",
      "command": "docker",
      "type": "shell",
      "args": [
        "build",
        "-t",
        "azureai-proxy",
        "-f",
        "${workspaceFolder}/src/Dockerfile.proxy",
        "${workspaceFolder}/src"
      ],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "docker build: admin",
      "command": "docker",
      "type": "shell",
      "args": [
        "build",
        "-t",
        "azureai-proxy-admin",
        "-f",
        "${workspaceFolder}/src/Dockerfile.admin",
        "${workspaceFolder}/src"
      ],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "e2e proxy unit and route tests",
      "type": "shell",
      "command": "dotnet test ${workspaceFolder}/src/AzureAIProxy.Tests/AzureAIProxy.Tests.csproj --verbosity normal",
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "test coverage summary",
      "type": "shell",
      "command": "rm -rf ${workspaceFolder}/src/AzureAIProxy.Tests/TestResults && dotnet test ${workspaceFolder}/src/AzureAIProxy.Tests/AzureAIProxy.Tests.csproj --collect:\"XPlat Code Coverage\" --verbosity normal && reportgenerator -reports:${workspaceFolder}/src/AzureAIProxy.Tests/TestResults/**/coverage.cobertura.xml -targetdir:${workspaceFolder}/src/AzureAIProxy.Tests/TestResults/Summary -reporttypes:TextSummary && cat ${workspaceFolder}/src/AzureAIProxy.Tests/TestResults/Summary/Summary.txt",
      "problemMatcher": "$msCompile",
      "group": "test"
    }
  ]
}
