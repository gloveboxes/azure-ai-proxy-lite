# -----------------------------------------------------------------
# Azure OpenAI Proxy — Local Docker Deployment
# Copy this file to .env and customise before running:
#   docker compose up -d
# -----------------------------------------------------------------

# ---- Proxy settings ----
PROXY_PORT=8910
ENCRYPTION_KEY=change-this-encryption-key-in-production
USE_MOCK_PROXY=false

# ---- Admin UI settings ----
ADMIN_PORT=8900
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ---- Registration SPA settings ----
REGISTRATION_PORT=4280
REGISTRATION_TLS_PORT=4443
REGISTRATION_HOST=localhost

# ---- Azurite (OSS Table Storage) ----
AZURITE_TABLE_PORT=10002

# ---- Docker image names (set before build/push) ----
PROXY_IMAGE=glovebox/aoai-proxy:latest
ADMIN_IMAGE=glovebox/aoai-proxy-admin:latest
REGISTRATION_IMAGE=glovebox/aoai-proxy-registration:latest
